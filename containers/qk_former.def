Bootstrap: docker
From: python:3.10-slim

%post
    set -eux

    apt-get update
    apt-get install -y --no-install-recommends \
        git \
        build-essential \
        screen \
        ca-certificates \
        wget \
        patchelf \
        libglib2.0-0 \
        libgl1
    rm -rf /var/lib/apt/lists/*

    python -m pip install --no-cache-dir --upgrade pip setuptools wheel

    python -m pip install --no-cache-dir \
        torch==1.12.1+cu116 \
        torchvision==0.13.1+cu116 \
        -f https://download.pytorch.org/whl/torch_stable.html

    python -m pip install --no-cache-dir \
        timm==0.6.12 \
        spikingjelly==0.0.0.0.12 \
        cupy-cuda11x==11.4.0 \
        numpy==1.23.5 \
        pyyaml \
        pandas \
        matplotlib \
        tensorboard \
        tabulate \
        tqdm \
        pytest \
        torchinfo

    python -m pip install --no-cache-dir \
        nvidia-cuda-runtime-cu11 \
        nvidia-cuda-nvrtc-cu11 \
        nvidia-cublas-cu11 \
        nvidia-cufft-cu11 \
        nvidia-curand-cu11 \
        nvidia-cusolver-cu11 \
        nvidia-cusparse-cu11

    SITE_PACKAGES="$(python - <<'PY'
import pathlib
import site

for site_dir in site.getsitepackages():
    if pathlib.Path(site_dir).exists():
        print(site_dir)
        break
PY
)"
    TORCH_LIB_DIR="$SITE_PACKAGES/torch/lib"
    NVIDIA_LIB_DIR="$SITE_PACKAGES/nvidia"
    find "$TORCH_LIB_DIR" -type f -name "*.so*" -exec patchelf --clear-execstack {} \;
    if [ -d "$NVIDIA_LIB_DIR" ]; then
        find "$NVIDIA_LIB_DIR" -type f -name "*.so*" -exec patchelf --clear-execstack {} \;
    fi

    export LD_LIBRARY_PATH="$TORCH_LIB_DIR:$NVIDIA_LIB_DIR/cuda_runtime/lib:$NVIDIA_LIB_DIR/cuda_nvrtc/lib:$NVIDIA_LIB_DIR/cublas/lib:$NVIDIA_LIB_DIR/cufft/lib:$NVIDIA_LIB_DIR/curand/lib:$NVIDIA_LIB_DIR/cusolver/lib:$NVIDIA_LIB_DIR/cusparse/lib:$LD_LIBRARY_PATH"

    python - <<'PY'
import torch
import cupy

print("torch:", torch.__version__)
print("cuda version:", torch.version.cuda)
print("cupy:", cupy.__version__)
PY

%environment
    export MPLBACKEND=Agg
    export PYTHONUNBUFFERED=1
    export PYTHON_SITE_PACKAGES=/usr/local/lib/python3.10/site-packages
    export LD_LIBRARY_PATH=$PYTHON_SITE_PACKAGES/torch/lib:$PYTHON_SITE_PACKAGES/nvidia/cuda_runtime/lib:$PYTHON_SITE_PACKAGES/nvidia/cuda_nvrtc/lib:$PYTHON_SITE_PACKAGES/nvidia/cublas/lib:$PYTHON_SITE_PACKAGES/nvidia/cufft/lib:$PYTHON_SITE_PACKAGES/nvidia/curand/lib:$PYTHON_SITE_PACKAGES/nvidia/cusolver/lib:$PYTHON_SITE_PACKAGES/nvidia/cusparse/lib:$LD_LIBRARY_PATH

%runscript
    set -e
    exec python "$@"
